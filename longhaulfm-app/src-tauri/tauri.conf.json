{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "longhaulfm-app",
  "version": "1.0.0",
  "identifier": "za.co.longhaulfm",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "https://192.168.8.2:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Longhaul FM",
        "width": 1000,
        "height": 800,
        "label": "main"
      }
    ],
    "security": {
      "capabilities": [
        "core-capability"
      ],
      "csp": "default-src 'self' https://tauri.localhost; script-src 'self' 'unsafe-eval' 'unsafe-inline' https://sdk.scdn.co; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob: https://*.scdn.co https://i.scdn.co https://longhaul-fm.co.za https://storage.googleapis.com; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://*.spotify.com https://sdk.scdn.co https://*.ably.io wss://*.ably.io https://longhaul-fm.co.za https://storage.googleapis.com;"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
 "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDg4RDdFNTI5M0NBRTEzODgKUldTSUU2NDhLZVhYaU9vZkgzNWdwQktETzBFSXpZSVdaWTFLL1JoMldSSVpWaWxaaDQxUkFaeGcK",
      "endpoints": [
        "https://longhaul-fm.co.za/api/update/{{target}}/{{current_version}}"
      ]
    },
    "deep-link": {
      "mobile": [
        {
          "host": "longhaul-fm.co.za",
          "pathPrefix": ["/auth/callback"],
          "scheme": ["longhaulfm"]
        }
      ]
    }
  }
}