{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "longhaulfm-app",
  "version": "0.1.0",
  "identifier": "com.user.longhaulfm-app",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "longhaulfm-app",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  {
    "plugins": {
      "deep-link": {
        "mobile": [
          {
            "host": "longhaul-fm.co.za",
            "pathPrefix": ["/callback"],
            "appLink": true
          }
        ]
      }
    }
  }
}
